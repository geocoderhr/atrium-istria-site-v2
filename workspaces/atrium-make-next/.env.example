NEXT_PUBLIC_SITE_URL=
PUBLIC_CHAT_ENABLED=false
PUBLIC_CHAT_API_BASE_URL=
PUBLIC_CHAT_ASK_PATH=/webhook/site-question
PUBLIC_CHAT_ANSWER_PATH=/webhook/site-answer
PUBLIC_CHAT_POLL_INTERVAL_MS=5000
# Google Tag Manager container id, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Optional GA4 context value passed into dataLayer for GTM mappings
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Optional debug logger for local validation: true|false
NEXT_PUBLIC_ANALYTICS_DEBUG=false
